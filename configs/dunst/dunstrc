[global]
  monitor = 0
  follow = mouse
  width = 360
  height = 120
  origin = top-right
  offset = 12x36
  scale = 0
  notification_limit = 5
  progress_bar = true
  transparency = 0
  separator_height = 2
  padding = 10
  horizontal_padding = 12
  frame_width = 2
  frame_color = "#89b4fa"
  font = JetBrainsMono Nerd Font 10
  markup = full
  format = "<b>%s</b>\n%b"
  sort = yes
  idle_threshold = 120
  line_height = 0
  show_age_threshold = 60
  word_wrap = yes
  ignore_newline = no
  stack_duplicates = true
  hide_duplicate_count = false
  show_indicators = yes

[urgency_low]
  background = "#1e1e2e"
  foreground = "#cdd6f4"
  timeout = 5

[urgency_normal]
  background = "#1e1e2e"
  foreground = "#cdd6f4"
  timeout = 8

[urgency_critical]
  background = "#1e1e2e"
  foreground = "#f38ba8"
  frame_color = "#f38ba8"
  timeout = 0
